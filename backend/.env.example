# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Encontre o Voice ID em: ElevenLabs > Voices > clique na voz > ID no painel
ELEVENLABS_VOICE_ID=your_voice_id_here

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change_this_to_a_random_secret_key

# User (perfil padrão)
DEFAULT_USER_ID=edgar

# GitHub (Personal Access Token)
# Crie em: github.com > Settings > Developer settings > Personal access tokens > Fine-grained tokens
# Permissões necessárias: Contents (read), Pull requests (read), Issues (read), Notifications (read)
GITHUB_TOKEN=your_github_pat_here
GITHUB_USERNAME=your_github_username_here

# Brave Search
# Crie em: api.search.brave.com — plano gratuito tem 2000 buscas/mês
BRAVE_API_KEY=your_brave_api_key_here
